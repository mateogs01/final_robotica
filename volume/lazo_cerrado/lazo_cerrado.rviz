    Help Height: 80
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Status1
        - /Map1
        - /Pose1
        - /Pose2/Status1
        - /Path1
        - /Path1/Status1
        - /RobotModel1
        - /RobotModel1/Mass Properties1
        - /RobotModel1/Links1
        - /Odometry1
        - /Odometry2
        - /Odometry2/Status1
        - /Odometry2/Shape1
      Splitter Ratio: 0.5668449401855469
    Tree Height: 783
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz_common/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: ""
